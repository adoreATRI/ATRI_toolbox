{
  "name": "atri-toolbox",
  "version": "0.2.0",
  "private": true,
  "description": "Cross-platform local toolbox for ATRI utilities.",
  "license": "MIT",
  "homepage": "https://github.com/adoreATRI/ATRI_toolbox#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adoreATRI/ATRI_toolbox.git"
  },
  "bugs": {
    "url": "https://github.com/adoreATRI/ATRI_toolbox/issues"
  },
  "desktopName": "atri-toolbox.desktop",
  "author": {
    "name": "ATRI",
    "email": "makochishima043@gmail.com"
  },
  "type": "module",
  "main": "desktop/main.cjs",
  "scripts": {
    "start": "node desktop/launch.cjs",
    "dev": "node desktop/launch.cjs",
    "serve": "node server.js",
    "check:syntax": "node --check mindmap-ai.js && node --check server.js && node --check desktop/main.cjs && node --check desktop/launch.cjs && node --check desktop/shutdown.cjs && node --check desktop/updater.cjs && node --check public/app.js",
    "test": "node --test",
    "check": "npm run check:syntax && npm test",
    "package:linux": "electron-builder --linux",
    "package:win": "electron-builder --win"
  },
  "engines": {
    "node": ">=22.12"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.atri.toolbox",
    "productName": "ATRI Toolbox",
    "icon": "public/assets/atri-logo.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "mindmap-ai.js",
      "server.js",
      "LICENSE",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "adoreATRI",
        "repo": "ATRI_toolbox"
      }
    ],
    "linux": {
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
